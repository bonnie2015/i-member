[
  {
    "agent": "plan",
    "task_id": "plan_001",
    "description": "退货场景：查订单→选商品→收原因→建单",
    "trials": 1,
    "setup": {
      "run_mode": "agent",
      "state_overrides": {
        "thread_id": "auto",
        "user_id": "test_user_001",
        "extra": {
          "service_key": "refund-ticket",
          "goal": "用户要退货，订单号 ORD-TEST-001，原因颜色不喜欢"
        }
      }
    },
    "expect": {
      "steps_min": 2,
      "steps_max": 5,
      "expected_slots_not_empty": true,
      "tools_allowed": ["get_user_orders", "get_order_detail", "get_product_detail", "create_ticket", "search_products", "read_file"]
    }
  },
  {
    "agent": "plan",
    "task_id": "plan_002",
    "description": "投诉场景：收集问题→建单",
    "trials": 1,
    "setup": {
      "run_mode": "agent",
      "state_overrides": {
        "thread_id": "auto",
        "user_id": "test_user_001",
        "extra": {
          "service_key": "unsatisfy-ticket",
          "goal": "用户投诉商品质量有问题"
        }
      }
    },
    "expect": {
      "steps_min": 2,
      "steps_max": 5,
      "expected_slots_not_empty": true,
      "tools_allowed": ["get_user_orders", "get_order_detail", "get_product_detail", "create_ticket", "get_ticket", "get_tickets"]
    }
  },
  {
    "agent": "plan",
    "task_id": "plan_003",
    "description": "查询场景：查已有工单，不能新建",
    "trials": 1,
    "setup": {
      "run_mode": "agent",
      "state_overrides": {
        "thread_id": "auto",
        "user_id": "test_user_001",
        "extra": {
          "service_key": "search-ticket",
          "goal": "用户想查已有工单进度"
        }
      }
    },
    "expect": {
      "steps_min": 1,
      "steps_max": 3,
      "tools_allowed": ["get_ticket", "get_tickets"],
      "tools_exclude": ["create_ticket"]
    }
  },
  {
    "agent": "plan",
    "task_id": "plan_004",
    "description": "无法规划：无理要求",
    "trials": 1,
    "setup": {
      "run_mode": "agent",
      "state_overrides": {
        "thread_id": "auto",
        "user_id": "test_user_001",
        "extra": {
          "service_key": "unsatisfy-ticket",
          "goal": "用户因为颜色不喜欢要求赔偿100万，否则投诉到消协"
        }
      }
    },
    "expect": {
      "steps_min": 0,
      "steps_max": 0,
      "reason_not_empty": true
    }
  },
  {
    "agent": "plan",
    "task_id": "plan_005",
    "description": "重规划无法继续：用户无订单",
    "trials": 1,
    "setup": {
      "run_mode": "agent",
      "state_overrides": {
        "thread_id": "auto",
        "user_id": "test_user_001",
        "extra": {
          "service_key": "refund-ticket",
          "goal": "用户要退货"
        },
        "failed_step": {
          "step_status": "failed",
          "goal": "查询用户订单",
          "try_process": [
            {"tool": "get_user_orders", "args": {}},
            {"tool": "get_user_orders", "result": "[]"}
          ]
        }
      }
    },
    "expect": {
      "steps_min": 1,
      "steps_max": 5,
      "reason_not_empty": true
    }
  },
  {
    "agent": "plan",
    "task_id": "plan_006",
    "description": "重规划可续：订单查询成功，步骤中断后重新规划",
    "trials": 1,
    "setup": {
      "run_mode": "agent",
      "state_overrides": {
        "thread_id": "auto",
        "user_id": "test_user_001",
        "extra": {
          "service_key": "refund-ticket",
          "goal": "用户要退货，订单号 ORD-TEST-001"
        },
        "failed_step": {
          "step_status": "failed",
          "goal": "查询并确认退货商品",
          "try_process": [
            {"tool": "get_user_orders", "args": {"order_id": "ORD-TEST-001"}},
            {"tool": "get_user_orders", "result": "[{\"order_id\": \"ORD-TEST-001\", \"items\": [{\"product_id\": 56077, \"color_id\": 19297, \"name\": \"MEXICO 66 SD 休闲鞋 米色/黑色\"}]}]"}
          ]
        }
      }
    },
    "expect": {
      "steps_min": 1,
      "steps_max": 5,
      "tools_allowed": ["get_user_orders", "get_order_detail", "get_product_detail", "create_ticket", "search_products", "read_file"]
    }
  }
]
