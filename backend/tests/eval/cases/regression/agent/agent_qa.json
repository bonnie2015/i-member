[
  {
    "agent": "qa",
    "task_id": "qa_001",
    "description": "查文档：退换货政策 RAG 检索并回答",
    "trials": 1,
    "setup": {
      "run_mode": "agent",
      "state_overrides": {
        "thread_id": "auto",
        "user_id": "test_user_001",
        "messages": [{"role": "human", "content": "退换货政策是什么"}]
      }
