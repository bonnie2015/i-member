    }
  },
  {
    "agent": "qa",
    "task_id": "qa_002",
    "description": "不查文档：闲聊不触发 RAG",
    "trials": 1,
    "setup": {
      "run_mode": "agent",
      "state_overrides": {
        "thread_id": "auto",
        "user_id": "test_user_001",
        "messages": [{"role": "human", "content": "你好"}]
      }
    },
    "expect": {
      "tool_trace_not_contains": ["rag_search"]
    }
  },
  {
    "agent": "qa",
    "task_id": "qa_003",
    "description": "召回验证：退换货时效",
    "trials": 1,
    "setup": {
      "run_mode": "agent",
      "state_overrides": {
        "thread_id": "auto",
        "user_id": "test_user_001",
        "messages": [{"role": "human", "content": "退换货的时效是多久"}]
