# Docker 镜像加速器（可选，国内构建加速）
# APT_MIRROR=http://mirrors.ustc.edu.cn
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# 端口
API_PORT=8000
FRONTEND_PORT=3000
REDIS_PORT=6379
REDIS_INSIGHT_PORT=8001

# Redis
REDIS_URL=redis://redis:6379/0

# Mock SCRM 模拟服务
SCRM_URL=http://scrm:3658

# DeepSeek API（主要 LLM 调用）
# 获取方式: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Ollama 本地模型（内部分类/压缩用）
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Qwen 阿里云 API（备用）
QWEN_API_KEY=

# Qdrant 向量数据库（RAG）
QDRANT_URL=http://qdrant:6333

# LlamaCloud 文档解析（可选）
# 获取方式: https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=

# Langfuse 可观测性（可选，agent trace 与 LLM 调用追踪）
# 注册地址: https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# JWT 密钥（生产环境必须修改）
JWT_SECRET_KEY=change-me-in-production

# 调试与日志
DEBUG=false
LOG_LEVEL=INFO
