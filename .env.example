# 环境变量示例 - Member Ops Agent
# 复制此文件为 .env 并填写实际值

# 基础配置
DEBUG=false
LOG_LEVEL=INFO

# Redis配置
# 本地开发: redis://localhost:6379/0
# Docker: redis://redis:6379/0
REDIS_URL=

# SCRM 服务配置
# Docker: http://scrm:3658
SCRM_URL=

# Ollama 配置
# 示例: http://192.168.1.100:11434
OLLAMA_BASE_URL=

# DeepSeek 配置
# 如果使用云端 DeepSeek 模型，请填写 API Key
# 获取方式: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Qdrant 向量数据库
# Docker: http://qdrant:6333
# 本地开发: http://localhost:6333
QDRANT_URL=http://qdrant:6333

# LlamaParse 配置
# 获取方式: https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=

# 注意：模型配置在 backend/app/config/models.json 中管理
